+	/*
+	 * Complete crash recovery even while the writable fence is closed, but
+	 * never begin a new primary WAL record without current authority.  Most
+	 * callers are already inside a critical section, so PANIC is intentional:
+	 * recovery is safer than allowing a page change without its WAL record.
+	 */
+	if (!AmStartupProcess() && !RecoveryInProgress() &&
+		!PgshardFenceRecoveryWalAllowed &&
+		unlikely(PgshardFenceWalInsertHook != NULL) &&
+		PgshardFenceWalInsertHook() != PGSHARD_FENCE_AUTHORITY_ALLOWED)
